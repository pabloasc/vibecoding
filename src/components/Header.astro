---
---

<header class="bg-white border-b border-[#EBEBEB]">

  <!-- 2px red top accent -->
  <div class="h-[2px] bg-[#CC0000]"></div>

  <!-- Single main row -->
  <div class="px-6 md:px-12 h-[64px] flex items-center justify-between">

    <!-- Logo + wordmark -->
    <a href="/" class="flex items-center gap-2 sm:gap-3 group shrink-0" aria-label="vibecoding.work home">
      <img
        src="/images/logo.png"
        alt=""
        class="h-7 sm:h-8 w-auto object-contain opacity-90 group-hover:opacity-50 transition-opacity duration-200"
      />
      <div class="leading-none">
        <div class="leading-none text-[1rem] sm:text-[1.15rem]" style="font-family: 'Space Grotesk', system-ui, sans-serif; font-weight: 700; letter-spacing: -0.02em;">
          <span class="text-[#0A0A0A]">vibecoding</span><span class="text-[#CC0000]">.work</span>
        </div>
        <p style="font-family: 'Space Grotesk', system-ui, sans-serif; font-weight: 300; font-size: 0.55rem; letter-spacing: 0.22em;" class="uppercase text-[#888] mt-[3px] hidden sm:block">
          The job board for vibecoders
        </p>
      </div>
    </a>

    <!-- Nav -->
    <nav class="flex items-center gap-1 sm:gap-2">
      <a href="/" class="nav-link font-mono text-[10px] tracking-[0.18em] uppercase px-3 py-2 text-[#555] hover:text-[#0A0A0A] transition-colors duration-150 relative hidden sm:block">
        Open Positions
      </a>
      <a href="/submit"
         class="font-mono text-[10px] tracking-[0.08em] sm:tracking-[0.18em] uppercase px-3 sm:px-4 py-2 border border-[#0A0A0A] text-[#0A0A0A]
                hover:bg-[#0A0A0A] hover:text-white transition-colors duration-150 whitespace-nowrap">
        Submit ↗
      </a>

      <!-- Auth status -->
      <div id="auth-nav" class="hidden items-center gap-1 sm:gap-2 ml-1">
        <span class="w-px h-3 bg-[#EBEBEB]"></span>
        <span id="auth-username" class="font-mono text-[10px] tracking-[0.15em] uppercase text-[#666] hidden sm:block"></span>
        <button id="auth-signout"
          class="font-mono text-[10px] tracking-[0.1em] sm:tracking-[0.15em] uppercase text-[#666] hover:text-[#CC0000] transition-colors duration-150 whitespace-nowrap">
          Sign out
        </button>
      </div>
    </nav>

  </div>

</header>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 2px;
    background: #CC0000;
    transition: width 0.2s ease;
  }
  .nav-link:hover::after,
  .nav-link[aria-current="page"]::after {
    width: 100%;
  }
</style>

<script>
  document.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach(link => {
    if (new URL(link.href).pathname === window.location.pathname) {
      link.style.color = '#0A0A0A';
      link.setAttribute('aria-current', 'page');
    }
  });
</script>

<script>
  import { supabase } from '../lib/supabase';

  const authNav      = document.getElementById('auth-nav')!;
  const authUsername = document.getElementById('auth-username')!;
  const signoutBtn   = document.getElementById('auth-signout')!;

  supabase.auth.onAuthStateChange((_event, session) => {
    if (session?.user) {
      const email = session.user.email ?? '';
      authUsername.textContent = email.split('@')[0];
      authNav.classList.remove('hidden');
      authNav.classList.add('flex');
    } else {
      authNav.classList.add('hidden');
      authNav.classList.remove('flex');
    }
  });

  signoutBtn.addEventListener('click', async () => {
    await supabase.auth.signOut();
    const gated = ['/submit', '/edit'];
    if (gated.some(p => window.location.pathname.startsWith(p))) {
      window.location.href = '/';
    }
  });
</script>
