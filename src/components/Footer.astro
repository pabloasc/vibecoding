---
const year = new Date().getFullYear();
---

<footer class="mt-16 bg-[#1A1A1A] text-[#F8F7F4]">

  <!-- Top accent rule -->
  <div class="h-[3px] bg-[#CC0000]"></div>

  <div class="px-6 md:px-12 py-10 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-8 border-b border-[#2a2a2a]">

    <!-- Brand -->
    <div>
      <a href="/" class="inline-flex items-center gap-3 group mb-4" aria-label="vibecoding.work home">
        <img
          src="/images/logo.png"
          alt="vibecoding.work"
          class="h-9 w-auto object-contain brightness-0 invert opacity-80 group-hover:opacity-50 transition-opacity duration-200"
        />
        <div class="leading-none">
          <span class="font-serif font-black text-[1.3rem] tracking-tight text-[#F8F7F4] leading-none">vibecoding</span><span
            class="font-mono font-medium text-[0.9rem] tracking-tight text-[#CC0000] leading-none">.work</span>
        </div>
      </a>
      <p class="font-mono text-[8px] tracking-[0.25em] uppercase text-[#444] leading-relaxed max-w-xs">
        The job board for AI-native builders — vibecoders who ship with intelligence.
      </p>
    </div>

    <!-- Links -->
    <div class="flex flex-col items-start md:items-end justify-between gap-4">
      <div class="flex flex-col gap-2.5 md:items-end">
        <a href="/submit" class="font-mono text-[9px] tracking-[0.25em] uppercase text-[#666] hover:text-[#CC0000] transition-colors duration-200">
          Submit a position ↗
        </a>
        <a href="/" class="font-mono text-[9px] tracking-[0.25em] uppercase text-[#666] hover:text-[#F8F7F4] transition-colors duration-200">
          Browse jobs
        </a>
      </div>
    </div>

  </div>

  <div class="px-6 md:px-12 py-3">
    <p class="font-mono text-[8px] tracking-[0.15em] text-[#333]">
      © {year} vibecoding.work — All rights reserved.
    </p>
  </div>

</footer>
