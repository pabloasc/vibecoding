---
const year = new Date().getFullYear();
---

<footer class="bg-[#0A0A0A] mt-20">
  <div class="max-w-6xl mx-auto px-6 md:px-8 py-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">

    <!-- Brand -->
    <div>
      <a href="/" class="inline-flex items-center gap-2.5 group mb-3" aria-label="vibecoding.work home">
        <img
          src="/images/logo_dark.png"
          alt=""
          class="h-7 w-auto brightness-0 invert opacity-50 group-hover:opacity-30 transition-opacity duration-200"
        />
        <span style="font-family: 'Space Grotesk', system-ui, sans-serif; font-weight: 700; font-size: 1rem; letter-spacing: -0.02em;" class="text-white">
          vibecoding<span class="text-[#CC0000]">.work</span>
        </span>
      </a>
      <p class="font-mono text-[0.6rem] tracking-[0.18em] uppercase text-[#333] leading-relaxed">
        The job board for AI-native builders.
      </p>
    </div>

    <!-- Links + copyright -->
    <div class="flex flex-col items-start sm:items-end gap-2.5">
      <a href="/submit" class="font-mono text-[0.6rem] tracking-[0.18em] uppercase text-[#444] hover:text-[#CC0000] transition-colors duration-150">
        Submit a position ↗
      </a>
      <a href="/" class="font-mono text-[0.6rem] tracking-[0.18em] uppercase text-[#444] hover:text-white transition-colors duration-150">
        Browse jobs
      </a>
      <span class="font-mono text-[0.55rem] tracking-[0.1em] uppercase text-[#2a2a2a] mt-1">
        © {year} vibecoding.work
      </span>
    </div>

  </div>
</footer>
