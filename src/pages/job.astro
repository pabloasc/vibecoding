---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Job Details — vibecoding.work"
  description="View this AI developer job opportunity on vibecoding.work."
>
  <Header />

  <main class="w-full">

    <!-- Loading state -->
    <div id="loading-state" class="px-6 md:px-12 py-24 text-center">
      <p class="font-mono text-[11px] tracking-[0.2em] uppercase text-[#888]">Loading…</p>
    </div>

    <!-- Error state -->
    <div id="error-state" class="hidden px-6 md:px-12 py-24 text-center">
      <p class="font-serif text-[2rem] font-black text-[#888] mb-4 leading-none">Position not found.</p>
      <a href="/" class="font-mono text-[11px] tracking-[0.25em] uppercase text-[#666]
                         hover:text-[#CC0000] transition-colors underline underline-offset-4">
        ← Back to listings
      </a>
    </div>

    <!-- Job detail -->
    <div id="job-detail" class="hidden">

      <!-- Back bar -->
      <div class="px-6 md:px-12 py-3 border-b border-[#D0CEC8] flex items-center justify-between">
        <a href="/"
           class="font-mono text-[11px] tracking-[0.2em] uppercase text-[#777]
                  hover:text-[#1A1A1A] transition-colors duration-150">
          ← All Positions
        </a>
        <span id="job-date" class="font-mono text-[10px] tracking-[0.15em] uppercase text-[#777]"></span>
      </div>

      <!-- Admin bar (hidden until admin auth confirmed) -->
      <div id="admin-bar" class="hidden px-6 md:px-12 py-2.5 bg-[#1A1A1A] flex items-center gap-4">
        <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-[#555]">Admin</span>
        <span class="w-px h-3 bg-[#333]"></span>
        <a id="admin-edit-link" href="#"
           class="font-mono text-[11px] tracking-[0.2em] uppercase text-[#F8F7F4]
                  hover:text-[#CC0000] transition-colors duration-150">
          Edit position →
        </a>
      </div>

      <!-- Hero image -->
      <div id="job-image-wrap" class="hidden w-full h-[260px] md:h-[360px] overflow-hidden bg-[#EFEFEC] relative">
        <div class="absolute inset-0 opacity-[0.06]"
             style="background-image:repeating-linear-gradient(45deg,#1A1A1A 0,#1A1A1A 1px,transparent 0,transparent 50%);background-size:6px 6px;"></div>
      </div>

      <!-- Content -->
      <div class="px-6 md:px-12 py-10 max-w-3xl">

        <!-- Label -->
        <p class="font-mono text-[11px] tracking-[0.35em] uppercase text-[#CC0000] mb-3">Open Position</p>

        <!-- Title -->
        <h1 id="job-title" class="font-serif text-[2rem] md:text-[2.8rem] font-black uppercase
                                  tracking-tight leading-none text-[#1A1A1A] mb-8"></h1>

        <!-- Description -->
        <div class="border-t border-[#D0CEC8] pt-8 mb-10">
          <p class="font-mono text-[11px] tracking-[0.3em] uppercase text-[#888] mb-4">About this role</p>
          <p id="job-description" class="font-sans text-[1rem] leading-relaxed text-[#333] whitespace-pre-wrap"></p>
        </div>

        <!-- Apply CTA -->
        <div class="border-t-2 border-[#1A1A1A] pt-8 flex items-center gap-6">
          <a id="job-apply-link"
             href="#"
             target="_blank"
             rel="noopener noreferrer"
             class="font-mono text-[11px] tracking-[0.3em] uppercase
                    bg-[#1A1A1A] text-[#F8F7F4] px-8 py-4
                    hover:bg-[#CC0000] transition-colors duration-200">
            Apply for this position ↗
          </a>
          <a href="/"
             class="font-mono text-[11px] tracking-[0.25em] uppercase text-[#777]
                    hover:text-[#1A1A1A] transition-colors duration-200">
            ← Back
          </a>
        </div>

      </div>
    </div>

  </main>

  <Footer />
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const ADMIN_EMAIL = 'hi@vibecoders.co';

  type Job = { id: string; title: string; description: string; image_url: string | null; link: string; created_at: string; };

  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase();
  }

  const loadingEl   = document.getElementById('loading-state')!;
  const errorEl     = document.getElementById('error-state')!;
  const detailEl    = document.getElementById('job-detail')!;

  async function loadJob() {
    const id = new URLSearchParams(window.location.search).get('id');
    if (!id) { showError(); return; }

    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/jobs?id=eq.${encodeURIComponent(id)}&select=*&limit=1`,
        { headers: { apikey: SUPABASE_ANON_KEY, Authorization: `Bearer ${SUPABASE_ANON_KEY}` } }
      );
      if (!res.ok) throw new Error();
      const jobs: Job[] = await res.json();
      if (!jobs.length) { showError(); return; }
      render(jobs[0]);
    } catch {
      showError();
    }
  }

  function showError() {
    loadingEl.classList.add('hidden');
    errorEl.classList.remove('hidden');
  }

  function render(job: Job) {
    document.title = `${job.title} — vibecoding.work`;

    (document.getElementById('job-title') as HTMLElement).textContent = job.title;
    (document.getElementById('job-description') as HTMLElement).textContent = job.description;
    (document.getElementById('job-date') as HTMLElement).textContent = formatDate(job.created_at);
    (document.getElementById('job-apply-link') as HTMLAnchorElement).href = job.link;

    if (job.image_url) {
      const wrap = document.getElementById('job-image-wrap')!;
      const img = document.createElement('img');
      img.src = job.image_url;
      img.alt = job.title;
      img.className = 'w-full h-full object-cover';
      wrap.appendChild(img);
      wrap.classList.remove('hidden');
    }

    loadingEl.classList.add('hidden');
    detailEl.classList.remove('hidden');

    // Check admin separately — getUser() validates the JWT server-side
    checkAdmin(job.id);
  }

  async function checkAdmin(jobId: string) {
    const { data: { user }, error } = await supabase.auth.getUser();
    if (!error && user?.email === ADMIN_EMAIL) {
      const bar = document.getElementById('admin-bar')!;
      const link = document.getElementById('admin-edit-link') as HTMLAnchorElement;
      link.href = `/edit?id=${jobId}`;
      bar.classList.remove('hidden');
    }
  }

  loadJob();
</script>
