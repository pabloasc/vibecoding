---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="404 — Page Not Found · vibecoding.work"
  description="The page you're looking for doesn't exist. Browse open vibe coder positions at vibecoding.work."
  noindex={true}
>
  <Header />

  <main class="w-full">

    <div class="px-6 md:px-12 py-24 md:py-36 max-w-2xl">

      <p class="font-mono text-[0.6rem] tracking-[0.3em] uppercase text-[#CC0000] mb-5">
        Error 404
      </p>

      <h1 class="font-sans font-bold text-[2.5rem] md:text-[3.8rem]
                 tracking-tight leading-none text-[#0A0A0A] mb-6">
        Position<br />Not Found.
      </h1>

      <div class="w-8 h-[2px] bg-[#EBEBEB] mb-8"></div>

      <p class="font-mono text-[0.75rem] leading-[1.8] text-[#666] mb-12 max-w-sm">
        This position may have been filled, removed, or the link is incorrect.
        Browse all open positions below.
      </p>

      <div class="flex items-center gap-6">
        <a href="/"
           class="font-mono text-[0.65rem] tracking-[0.25em] uppercase
                  bg-[#0A0A0A] text-white px-7 py-3.5
                  hover:bg-[#CC0000] transition-colors duration-200">
          Browse open positions →
        </a>
        <a href="/submit"
           class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-[#CACACA]
                  hover:text-[#0A0A0A] transition-colors duration-200">
          Submit a job ↗
        </a>
      </div>

    </div>

    <div class="border-t border-[#F2F2F2] mx-6 md:mx-12"></div>

    <div class="px-6 md:px-12 py-10 max-w-2xl">
      <p class="font-sans font-light text-[1rem] text-[#AAA] leading-relaxed">
        "The best vibe coder jobs are still out there — you just have to look."
      </p>
    </div>

  </main>

  <Footer />
</Layout>
