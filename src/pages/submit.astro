---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const webPage = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Post an AI Developer Job — vibecoding.work',
  url: 'https://vibecoding.work/submit',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home',               item: 'https://vibecoding.work/'       },
      { '@type': 'ListItem', position: 2, name: 'Submit a Position',  item: 'https://vibecoding.work/submit' },
    ],
  },
});
---

<Layout
  title="Post an AI Developer Job — vibecoding.work"
  description="Post a remote job opening on vibecoding.work. Reach the best vibecoders and AI-native software engineers who build fast and ship faster."
>
  <script slot="head" type="application/ld+json" set:html={webPage} />
  <Header />

  <main class="px-5 md:px-12 py-12 max-w-2xl">

    <!-- Section header -->
    <div class="border-b-2 border-[#1A1A1A] pb-5 mb-10">
      <p class="font-mono text-[11px] tracking-[0.35em] uppercase text-[#CC0000] mb-1.5">Contribute</p>
      <h2 class="font-serif text-[2rem] md:text-[2.5rem] font-black uppercase tracking-tight leading-none text-[#1A1A1A]">Submit a Position</h2>
    </div>

    <!-- Auth checking state -->
    <div id="auth-checking" class="py-12 text-center">
      <p class="font-mono text-[11px] tracking-[0.2em] uppercase text-[#888]">Checking session…</p>
    </div>

    <!-- Auth wall -->
    <div id="auth-wall" class="hidden">
      <div class="border border-[#D0CEC8] bg-[#F2F0EC] mb-10">

        <!-- Tabs -->
        <div class="flex border-b border-[#D0CEC8]">
          <button id="tab-signin"
            class="flex-1 font-mono text-[11px] tracking-[0.25em] uppercase py-3.5
                   border-b-2 border-[#1A1A1A] text-[#1A1A1A] transition-colors duration-150">
            Sign in
          </button>
          <button id="tab-signup"
            class="flex-1 font-mono text-[11px] tracking-[0.25em] uppercase py-3.5
                   border-b-2 border-transparent text-[#888] hover:text-[#1A1A1A] transition-colors duration-150">
            Sign up
          </button>
        </div>

        <div class="p-8">

          <!-- Auth error -->
          <div id="auth-error" class="hidden bg-[#CC0000] text-white px-5 py-3 mb-4">
            <p class="font-mono text-[11px] tracking-[0.2em] uppercase" id="auth-error-msg">An error occurred.</p>
          </div>

          <!-- Sign-up success -->
          <div id="signup-success" class="hidden bg-[#1A1A1A] text-[#F8F7F4] p-6 mb-4">
            <p class="font-mono text-[11px] tracking-[0.25em] uppercase text-[#CC0000] mb-2">Almost there</p>
            <p class="font-serif text-[1.2rem] font-black leading-tight">Check your email.</p>
            <p class="font-sans text-sm text-[#888] mt-2">Click the confirmation link to activate your account, then sign in.</p>
          </div>

          <!-- Sign in form -->
          <form id="login-form" class="space-y-3">
            <input
              type="email"
              id="login-email"
              required
              placeholder="Email"
              autocomplete="email"
              class="w-full border border-[#ccc] bg-white px-4 py-3
                     font-mono text-sm text-[#1A1A1A] placeholder:text-[#ccc]
                     focus:outline-none focus:border-[#1A1A1A]
                     transition-colors duration-200"
            />
            <input
              type="password"
              id="login-password"
              required
              placeholder="Password"
              autocomplete="current-password"
              class="w-full border border-[#ccc] bg-white px-4 py-3
                     font-mono text-sm text-[#1A1A1A] placeholder:text-[#ccc]
                     focus:outline-none focus:border-[#1A1A1A]
                     transition-colors duration-200"
            />
            <button
              type="submit"
              id="login-btn"
              class="font-mono text-[11px] tracking-[0.25em] uppercase
                     bg-[#1A1A1A] text-[#F8F7F4] px-6 py-3 w-full
                     hover:bg-[#CC0000] transition-colors duration-200
                     disabled:opacity-40 disabled:cursor-not-allowed"
            >
              Sign in →
            </button>
          </form>

          <!-- Sign up form (hidden by default) -->
          <form id="signup-form" class="hidden space-y-3">
            <input
              type="email"
              id="signup-email"
              required
              placeholder="Email"
              autocomplete="email"
              class="w-full border border-[#ccc] bg-white px-4 py-3
                     font-mono text-sm text-[#1A1A1A] placeholder:text-[#ccc]
                     focus:outline-none focus:border-[#1A1A1A]
                     transition-colors duration-200"
            />
            <input
              type="password"
              id="signup-password"
              required
              placeholder="Password"
              autocomplete="new-password"
              class="w-full border border-[#ccc] bg-white px-4 py-3
                     font-mono text-sm text-[#1A1A1A] placeholder:text-[#ccc]
                     focus:outline-none focus:border-[#1A1A1A]
                     transition-colors duration-200"
            />
            <input
              type="password"
              id="signup-confirm"
              required
              placeholder="Confirm password"
              autocomplete="new-password"
              class="w-full border border-[#ccc] bg-white px-4 py-3
                     font-mono text-sm text-[#1A1A1A] placeholder:text-[#ccc]
                     focus:outline-none focus:border-[#1A1A1A]
                     transition-colors duration-200"
            />
            <button
              type="submit"
              id="signup-btn"
              class="font-mono text-[11px] tracking-[0.25em] uppercase
                     bg-[#1A1A1A] text-[#F8F7F4] px-6 py-3 w-full
                     hover:bg-[#CC0000] transition-colors duration-200
                     disabled:opacity-40 disabled:cursor-not-allowed"
            >
              Create account →
            </button>
          </form>

        </div>
      </div>
    </div>

    <!-- Success state -->
    <div id="success-state" class="hidden bg-[#1A1A1A] text-[#F8F7F4] p-10 mb-8">
      <p class="font-mono text-[11px] tracking-[0.3em] uppercase text-[#CC0000] mb-3">Position Submitted</p>
      <p class="font-serif text-[2rem] font-black mb-6 leading-none">Your listing is live.</p>
      <a href="/" class="font-mono text-[11px] tracking-[0.2em] uppercase text-[#888] hover:text-[#CC0000] transition-colors duration-200 border-b border-[#444] pb-px">
        ← Back to listings
      </a>
    </div>

    <!-- Error banner -->
    <div id="error-banner" class="hidden bg-[#CC0000] text-white px-5 py-3.5 mb-6">
      <p class="font-mono text-[11px] tracking-[0.2em] uppercase" id="error-message">An error occurred.</p>
    </div>

    <!-- Form (hidden until authenticated) -->
    <form id="submit-form" class="hidden space-y-8" novalidate>

      <!-- Title -->
      <div class="space-y-2.5">
        <label for="title" class="block font-mono text-[11px] tracking-[0.3em] uppercase text-[#888]">
          Job Title <span class="text-[#CC0000]">*</span>
        </label>
        <input
          type="text"
          id="title"
          name="title"
          required
          placeholder="e.g. Senior AI Engineer"
          class="w-full border border-[#ccc] bg-white px-4 py-4
                 font-serif text-lg text-[#1A1A1A] placeholder:text-[#ccc]
                 focus:outline-none focus:border-[#1A1A1A]
                 transition-colors duration-200"
        />
      </div>

      <!-- Description -->
      <div class="space-y-2.5">
        <label for="description" class="block font-mono text-[11px] tracking-[0.3em] uppercase text-[#888]">
          Description <span class="text-[#CC0000]">*</span>
        </label>
        <textarea
          id="description"
          name="description"
          required
          rows="5"
          placeholder="Describe the role, requirements, and what makes it special for a vibecoder…"
          class="w-full border border-[#ccc] bg-white px-4 py-4
                 font-sans text-sm leading-relaxed text-[#1A1A1A] placeholder:text-[#ccc]
                 focus:outline-none focus:border-[#1A1A1A]
                 transition-colors duration-200 resize-none"
        ></textarea>
      </div>

      <!-- Link -->
      <div class="space-y-2.5">
        <label for="link" class="block font-mono text-[11px] tracking-[0.3em] uppercase text-[#888]">
          Application URL <span class="text-[#CC0000]">*</span>
        </label>
        <input
          type="url"
          id="link"
          name="link"
          required
          placeholder="https://jobs.example.com/position"
          class="w-full border border-[#ccc] bg-white px-4 py-4
                 font-mono text-sm text-[#1A1A1A] placeholder:text-[#ccc]
                 focus:outline-none focus:border-[#1A1A1A]
                 transition-colors duration-200"
        />
      </div>

      <!-- Image -->
      <div class="space-y-2.5">
        <label class="block font-mono text-[11px] tracking-[0.3em] uppercase text-[#888]">
          Cover Image <span class="text-[#999]">(optional)</span>
        </label>

        <!-- Source tabs -->
        <div class="flex border border-[#D0CEC8]">
          <button type="button" id="img-tab-upload"
            class="flex-1 font-mono text-[11px] tracking-[0.2em] uppercase py-2.5
                   bg-[#1A1A1A] text-[#F8F7F4] transition-colors duration-150">
            Upload file
          </button>
          <button type="button" id="img-tab-url"
            class="flex-1 font-mono text-[11px] tracking-[0.2em] uppercase py-2.5
                   bg-white text-[#888] hover:text-[#1A1A1A] transition-colors duration-150">
            External URL
          </button>
        </div>

        <!-- Upload pane -->
        <div id="img-pane-upload">
          <div id="drop-zone"
            class="border border-dashed border-[#ccc] bg-white p-12 text-center cursor-pointer
                   hover:border-[#1A1A1A] transition-colors duration-200 relative"
          >
            <input type="file" id="image" name="image" accept="image/jpeg,image/png,image/webp"
              class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
            <div id="drop-prompt">
              <p class="font-serif text-[1.4rem] font-black mb-2 text-[#1A1A1A]">Drop image here</p>
              <p class="font-mono text-[11px] tracking-[0.2em] text-[#777] uppercase">
                or click to browse &nbsp;·&nbsp; JPG, PNG, WebP &nbsp;·&nbsp; max 5 MB
              </p>
            </div>
            <div id="image-preview-wrap" class="hidden">
              <img id="image-preview" src="" alt="Preview"
                class="max-h-52 mx-auto border border-[#1A1A1A] grayscale" />
              <p class="font-mono text-[11px] tracking-[0.2em] text-[#777] uppercase mt-3" id="image-name"></p>
              <button type="button" id="remove-image"
                class="font-mono text-[11px] tracking-[0.2em] uppercase text-[#CC0000]
                       border-b border-[#CC0000] pb-px mt-2 hover:opacity-70 transition-opacity">
                Remove
              </button>
            </div>
          </div>
        </div>

        <!-- URL pane (hidden by default) -->
        <div id="img-pane-url" class="hidden space-y-3">
          <input
            type="url"
            id="image-url"
            placeholder="https://example.com/image.jpg"
            class="w-full border border-[#ccc] bg-white px-4 py-3
                   font-mono text-sm text-[#1A1A1A] placeholder:text-[#ccc]
                   focus:outline-none focus:border-[#1A1A1A]
                   transition-colors duration-200"
          />
          <div id="url-preview-wrap" class="hidden border border-[#D0CEC8] p-4 bg-[#F8F7F4]">
            <img id="url-preview" src="" alt="URL preview"
              class="max-h-40 border border-[#1A1A1A] grayscale" />
            <button type="button" id="clear-url"
              class="font-mono text-[11px] tracking-[0.2em] uppercase text-[#CC0000]
                     border-b border-[#CC0000] pb-px mt-3 block hover:opacity-70 transition-opacity">
              Clear
            </button>
          </div>
        </div>
      </div>

      <!-- Submit row -->
      <div class="flex items-center gap-6 pt-6 border-t border-[#1A1A1A]">
        <button
          type="submit"
          id="submit-btn"
          class="font-mono text-[11px] tracking-[0.3em] uppercase
                 bg-[#1A1A1A] text-[#F8F7F4] px-8 py-4
                 hover:bg-[#CC0000] transition-colors duration-200
                 disabled:opacity-40 disabled:cursor-not-allowed"
        >
          Publish Position →
        </button>
        <a href="/"
          class="font-mono text-[11px] tracking-[0.25em] uppercase text-[#777] hover:text-[#1A1A1A] transition-colors duration-200">
          Cancel
        </a>
      </div>

    </form>
  </main>

  <Footer />
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  // ── Auth state ────────────────────────────────────────────
  const authCheckingEl = document.getElementById('auth-checking')!;
  const authWallEl     = document.getElementById('auth-wall')!;
  const submitFormEl   = document.getElementById('submit-form') as HTMLFormElement;
  let currentToken: string = SUPABASE_ANON_KEY;

  function showAuthWall() {
    authCheckingEl.classList.add('hidden');
    authWallEl.classList.remove('hidden');
    submitFormEl.classList.add('hidden');
  }

  function showForm() {
    authCheckingEl.classList.add('hidden');
    authWallEl.classList.add('hidden');
    submitFormEl.classList.remove('hidden');
  }

  supabase.auth.onAuthStateChange((_event, session) => {
    currentToken = session?.access_token ?? SUPABASE_ANON_KEY;
    if (session) {
      showForm();
    } else {
      showAuthWall();
    }
  });

  // ── Tab switching ─────────────────────────────────────────
  const tabSignin  = document.getElementById('tab-signin')!;
  const tabSignup  = document.getElementById('tab-signup')!;
  const loginFormEl  = document.getElementById('login-form') as HTMLFormElement;
  const signupFormEl = document.getElementById('signup-form') as HTMLFormElement;
  const authErrorEl  = document.getElementById('auth-error')!;
  const authErrorMsg = document.getElementById('auth-error-msg')!;
  const signupSuccessEl = document.getElementById('signup-success')!;

  const activeTab   = 'border-b-2 border-[#1A1A1A] text-[#1A1A1A]';
  const inactiveTab = 'border-b-2 border-transparent text-[#888] hover:text-[#1A1A1A]';

  function switchToSignin() {
    tabSignin.className = `flex-1 font-mono text-[11px] tracking-[0.25em] uppercase py-3.5 transition-colors duration-150 ${activeTab}`;
    tabSignup.className = `flex-1 font-mono text-[11px] tracking-[0.25em] uppercase py-3.5 transition-colors duration-150 ${inactiveTab}`;
    loginFormEl.classList.remove('hidden');
    signupFormEl.classList.add('hidden');
    authErrorEl.classList.add('hidden');
    signupSuccessEl.classList.add('hidden');
  }

  function switchToSignup() {
    tabSignup.className = `flex-1 font-mono text-[11px] tracking-[0.25em] uppercase py-3.5 transition-colors duration-150 ${activeTab}`;
    tabSignin.className = `flex-1 font-mono text-[11px] tracking-[0.25em] uppercase py-3.5 transition-colors duration-150 ${inactiveTab}`;
    signupFormEl.classList.remove('hidden');
    loginFormEl.classList.add('hidden');
    authErrorEl.classList.add('hidden');
    signupSuccessEl.classList.add('hidden');
  }

  tabSignin.addEventListener('click', switchToSignin);
  tabSignup.addEventListener('click', switchToSignup);

  // ── Sign in ───────────────────────────────────────────────
  const loginBtn = document.getElementById('login-btn') as HTMLButtonElement;

  loginFormEl.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email    = (document.getElementById('login-email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('login-password') as HTMLInputElement).value;
    if (!email || !password) return;

    loginBtn.disabled = true;
    loginBtn.textContent = 'Signing in…';
    authErrorEl.classList.add('hidden');

    const { error } = await supabase.auth.signInWithPassword({ email, password });

    loginBtn.disabled = false;
    loginBtn.textContent = 'Sign in →';

    if (error) {
      authErrorMsg.textContent = error.message;
      authErrorEl.classList.remove('hidden');
    }
    // On success, onAuthStateChange fires and calls showForm()
  });

  // ── Sign up ───────────────────────────────────────────────
  const signupBtn = document.getElementById('signup-btn') as HTMLButtonElement;

  signupFormEl.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email    = (document.getElementById('signup-email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('signup-password') as HTMLInputElement).value;
    const confirm  = (document.getElementById('signup-confirm') as HTMLInputElement).value;

    if (!email || !password) return;
    if (password !== confirm) {
      authErrorMsg.textContent = 'Passwords do not match.';
      authErrorEl.classList.remove('hidden');
      return;
    }

    signupBtn.disabled = true;
    signupBtn.textContent = 'Creating account…';
    authErrorEl.classList.add('hidden');

    const { error } = await supabase.auth.signUp({ email, password });

    signupBtn.disabled = false;
    signupBtn.textContent = 'Create account →';

    if (error) {
      authErrorMsg.textContent = error.message;
      authErrorEl.classList.remove('hidden');
    } else {
      signupFormEl.classList.add('hidden');
      signupSuccessEl.classList.remove('hidden');
    }
    // If email confirmation is disabled in Supabase, onAuthStateChange fires immediately
  });

  // ── Image source tabs ─────────────────────────────────────
  let imageSource: 'file' | 'url' = 'file';
  const imgTabUpload  = document.getElementById('img-tab-upload') as HTMLButtonElement;
  const imgTabUrl     = document.getElementById('img-tab-url') as HTMLButtonElement;
  const imgPaneUpload = document.getElementById('img-pane-upload')!;
  const imgPaneUrl    = document.getElementById('img-pane-url')!;

  imgTabUpload.addEventListener('click', () => {
    imageSource = 'file';
    imgTabUpload.className = 'flex-1 font-mono text-[11px] tracking-[0.2em] uppercase py-2.5 bg-[#1A1A1A] text-[#F8F7F4] transition-colors duration-150';
    imgTabUrl.className    = 'flex-1 font-mono text-[11px] tracking-[0.2em] uppercase py-2.5 bg-white text-[#888] hover:text-[#1A1A1A] transition-colors duration-150';
    imgPaneUpload.classList.remove('hidden');
    imgPaneUrl.classList.add('hidden');
  });

  imgTabUrl.addEventListener('click', () => {
    imageSource = 'url';
    imgTabUrl.className    = 'flex-1 font-mono text-[11px] tracking-[0.2em] uppercase py-2.5 bg-[#1A1A1A] text-[#F8F7F4] transition-colors duration-150';
    imgTabUpload.className = 'flex-1 font-mono text-[11px] tracking-[0.2em] uppercase py-2.5 bg-white text-[#888] hover:text-[#1A1A1A] transition-colors duration-150';
    imgPaneUrl.classList.remove('hidden');
    imgPaneUpload.classList.add('hidden');
  });

  // ── File upload preview ────────────────────────────────────
  const imageInput = document.getElementById('image') as HTMLInputElement;
  const dropPrompt = document.getElementById('drop-prompt')!;
  const previewWrap = document.getElementById('image-preview-wrap')!;
  const previewImg = document.getElementById('image-preview') as HTMLImageElement;
  const imageName = document.getElementById('image-name')!;
  const removeBtn = document.getElementById('remove-image')!;

  imageInput.addEventListener('change', () => {
    const file = imageInput.files?.[0];
    if (!file) return;
    showPreview(file);
  });

  removeBtn.addEventListener('click', () => {
    imageInput.value = '';
    previewWrap.classList.add('hidden');
    dropPrompt.classList.remove('hidden');
  });

  function showPreview(file: File) {
    const reader = new FileReader();
    reader.onload = (e) => {
      previewImg.src = e.target?.result as string;
      imageName.textContent = file.name;
      dropPrompt.classList.add('hidden');
      previewWrap.classList.remove('hidden');
    };
    reader.readAsDataURL(file);
  }

  // ── URL preview ───────────────────────────────────────────
  const imageUrlInput  = document.getElementById('image-url') as HTMLInputElement;
  const urlPreviewWrap = document.getElementById('url-preview-wrap')!;
  const urlPreviewImg  = document.getElementById('url-preview') as HTMLImageElement;
  let urlDebounce: ReturnType<typeof setTimeout> | null = null;

  imageUrlInput.addEventListener('input', () => {
    if (urlDebounce) clearTimeout(urlDebounce);
    urlDebounce = setTimeout(() => {
      const url = imageUrlInput.value.trim();
      if (!url) { urlPreviewWrap.classList.add('hidden'); return; }
      urlPreviewImg.onload  = () => urlPreviewWrap.classList.remove('hidden');
      urlPreviewImg.onerror = () => urlPreviewWrap.classList.add('hidden');
      urlPreviewImg.src = url;
    }, 500);
  });

  document.getElementById('clear-url')!.addEventListener('click', () => {
    imageUrlInput.value = '';
    urlPreviewImg.src = '';
    urlPreviewWrap.classList.add('hidden');
  });

  // ── Form submission ───────────────────────────────────────
  const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const successEl  = document.getElementById('success-state')!;
  const errorBanner  = document.getElementById('error-banner')!;
  const errorMessage = document.getElementById('error-message')!;

  function showError(msg: string) {
    errorMessage.textContent = msg;
    errorBanner.classList.remove('hidden');
    errorBanner.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function hideError() {
    errorBanner.classList.add('hidden');
  }

  submitFormEl.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    const title       = (document.getElementById('title') as HTMLInputElement).value.trim();
    const description = (document.getElementById('description') as HTMLTextAreaElement).value.trim();
    const link        = (document.getElementById('link') as HTMLInputElement).value.trim();
    const imageFile    = imageSource === 'file' ? (imageInput.files?.[0] ?? null) : null;
    const imageExtUrl  = imageSource === 'url'  ? imageUrlInput.value.trim() : null;

    if (!title)       { showError('Job title is required.'); return; }
    if (!description) { showError('Description is required.'); return; }
    if (!link)        { showError('Application URL is required.'); return; }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Publishing…';

    try {
      let image_url: string | null = imageExtUrl || null;

      if (imageFile) {
        if (imageFile.size > 5 * 1024 * 1024) {
          showError('Image must be smaller than 5 MB.');
          return;
        }

        const ext = imageFile.name.split('.').pop();
        const filename = `${crypto.randomUUID()}.${ext}`;

        const uploadRes = await fetch(
          `${SUPABASE_URL}/storage/v1/object/job-images/${filename}`,
          {
            method: 'POST',
            headers: {
              apikey: SUPABASE_ANON_KEY,
              Authorization: `Bearer ${currentToken}`,
              'Content-Type': imageFile.type,
              'x-upsert': 'false',
            },
            body: imageFile,
          }
        );

        if (!uploadRes.ok) {
          const err = await uploadRes.json().catch(() => ({}));
          throw new Error(err?.message || 'Image upload failed.');
        }

        image_url = `${SUPABASE_URL}/storage/v1/object/public/job-images/${filename}`;
      }

      const insertRes = await fetch(`${SUPABASE_URL}/rest/v1/jobs`, {
        method: 'POST',
        headers: {
          apikey: SUPABASE_ANON_KEY,
          Authorization: `Bearer ${currentToken}`,
          'Content-Type': 'application/json',
          Prefer: 'return=minimal',
        },
        body: JSON.stringify({ title, description, link, image_url }),
      });

      if (!insertRes.ok) {
        const err = await insertRes.json().catch(() => ({}));
        throw new Error(err?.message || 'Failed to save the position.');
      }

      submitFormEl.classList.add('hidden');
      successEl.classList.remove('hidden');
      successEl.scrollIntoView({ behavior: 'smooth' });

    } catch (err: unknown) {
      showError(err instanceof Error ? err.message : 'An unexpected error occurred.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Publish Position →';
    }
  });
</script>
