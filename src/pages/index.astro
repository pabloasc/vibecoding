---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="vibecoding.work — AI Developer Jobs & Remote Opportunities"
  description="Browse open positions for vibecoders and AI-native developers. Find jobs that embrace AI-assisted development and ship at the speed of thought."
>
  <Header />

  <main class="w-full">

    <!-- ─── Section header ─────────────────────────────────── -->
    <div class="px-6 md:px-12 py-4 border-b border-[#EBEBEB] flex items-center justify-between">
      <div class="flex items-center gap-3">
        <h2 class="font-sans font-semibold text-[0.75rem] tracking-[0.18em] uppercase text-[#0A0A0A]">
          Open Positions
        </h2>
        <span class="font-mono text-[0.6rem] tracking-[0.15em] uppercase text-[#CC0000]"></span>
      </div>
      <span id="job-count" class="font-mono text-[0.6rem] tracking-[0.15em] uppercase text-[#888]">
        Loading…
      </span>
    </div>

    <!-- ─── Loading skeleton ─────────────────────────────────── -->
    <div id="loading-state" class="divide-y divide-[#F4F4F4]">
      {[...Array(6)].map(() => (
        <div class="flex items-start gap-5 px-6 md:px-12 py-5 animate-pulse">
          <div class="w-[52px] h-[52px] md:w-[80px] md:h-[80px] bg-[#F4F4F4] shrink-0 mt-0.5"></div>
          <div class="flex-1 min-w-0 space-y-2">
            <div class="h-3.5 bg-[#F4F4F4] rounded-sm w-2/5"></div>
            <div class="h-2.5 bg-[#F4F4F4] rounded-sm w-full"></div>
            <div class="h-2.5 bg-[#F4F4F4] rounded-sm w-3/4"></div>
            <div class="flex gap-2 mt-1">
              <div class="h-4 w-14 bg-[#F4F4F4] rounded-full"></div>
              <div class="h-4 w-16 bg-[#F4F4F4] rounded-full"></div>
              <div class="h-4 w-12 bg-[#F4F4F4] rounded-full ml-auto"></div>
            </div>
          </div>
          <div class="h-2.5 w-10 bg-[#F4F4F4] rounded-sm hidden sm:block shrink-0 mt-1"></div>
        </div>
      ))}
    </div>

    <!-- ─── Empty state ─────────────────────────────────────── -->
    <div id="empty-state" class="hidden px-6 md:px-12 py-24 text-center border-b border-[#EBEBEB]">
      <p class="font-sans font-semibold text-[1.5rem] text-[#888] mb-4 leading-none">No positions yet.</p>
      <a href="/submit"
        class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-[#666] hover:text-[#CC0000] transition-colors underline-offset-4 underline">
        Be the first to submit one ↗
      </a>
    </div>

    <!-- ─── Error state ──────────────────────────────────────── -->
    <div id="error-state" class="hidden px-6 md:px-12 py-12 text-center">
      <p class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-[#CC0000]">
        Failed to load positions.
      </p>
    </div>

    <!-- ─── Job list ─────────────────────────────────────────── -->
    <div id="job-list" class="hidden"></div>

    <!-- ─── Pagination ───────────────────────────────────────── -->
    <div id="pagination" class="hidden px-6 md:px-12 py-5 border-t border-[#EBEBEB] flex items-center justify-between gap-4">
      <button id="page-prev"
        class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-[#666]
               hover:text-[#0A0A0A] transition-colors duration-150 disabled:opacity-30 disabled:cursor-not-allowed">
        ← Prev
      </button>
      <span id="page-indicator" class="font-mono text-[0.6rem] tracking-[0.15em] uppercase text-[#888]"></span>
      <button id="page-next"
        class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-[#666]
               hover:text-[#0A0A0A] transition-colors duration-150 disabled:opacity-30 disabled:cursor-not-allowed">
        Next →
      </button>
    </div>

  </main>

  <Footer />
</Layout>

<!-- ═══════ ROW TEMPLATE ══════════════════════════════════════ -->
<template id="tpl-row">
  <article class="group relative flex items-start gap-5 px-6 md:px-12 py-5 border-b border-[#F2F2F2]
                  hover:bg-[#FAFAFA] transition-colors duration-100 cursor-pointer">

    <!-- Thumbnail — clean square -->
    <div class="job-image-wrap w-[52px] h-[52px] md:w-[80px] md:h-[80px] shrink-0 overflow-hidden bg-[#F4F4F4] flex items-center justify-center mt-0.5"></div>

    <!-- Title + description + meta -->
    <div class="flex-1 min-w-0">
      <h2 class="job-title font-sans font-semibold text-[0.92rem] md:text-[1rem] leading-snug truncate text-[#0A0A0A]
                 group-hover:text-[#CC0000] transition-colors duration-100"></h2>
      <p class="job-description font-mono text-[0.65rem] md:text-[0.75rem] text-[#888] mt-1.5 leading-relaxed line-clamp-2 md:line-clamp-3"></p>
      <div class="flex items-center gap-2 mt-2 flex-wrap">
        <div class="job-tags flex items-center gap-1.5 flex-wrap"></div>
        <span class="job-date font-mono text-[0.52rem] tracking-[0.08em] text-[#B0B0B0] uppercase whitespace-nowrap"></span>
      </div>
    </div>

    <!-- Apply link -->
    <a class="job-link relative z-10 font-mono text-[0.6rem] tracking-[0.18em] uppercase
              text-[#CC0000] shrink-0 whitespace-nowrap hidden sm:block mt-0.5
              hover:underline underline-offset-2"
       target="_blank" rel="noopener noreferrer">Apply ↗</a>

    <!-- Full-row tap target -->
    <a class="job-card-link absolute inset-0 z-0"
       aria-hidden="true" tabindex="-1"></a>
  </article>
</template>

<script>
  import { jobSlug } from '../lib/slug';

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const PAGE_SIZE = 15;

  type Job = { id: string; title: string; description: string; image_url: string | null; link: string; created_at: string; is_remote: boolean | null; locations: string[] | null; salary_min: number | null; salary_max: number | null; };

  let currentPage = 0;
  let totalCount   = 0;

  const loadingEl   = document.getElementById('loading-state')!;
  const emptyEl     = document.getElementById('empty-state')!;
  const errorEl     = document.getElementById('error-state')!;
  const countEl     = document.getElementById('job-count')!;
  const listEl      = document.getElementById('job-list')!;
  const paginationEl = document.getElementById('pagination')!;
  const prevBtn     = document.getElementById('page-prev') as HTMLButtonElement;
  const nextBtn     = document.getElementById('page-next') as HTMLButtonElement;
  const indicatorEl = document.getElementById('page-indicator')!;

  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase();
  }

  function showInitialAvatar(wrap: Element, title: string) {
    const letter = title.trim()[0]?.toUpperCase() ?? '?';
    wrap.innerHTML = `<span style="font-family:'IBM Plex Mono',monospace;font-size:1.3rem;font-weight:600;color:#1A1A1A;line-height:1;">${letter}</span>`;
  }

  function injectImage(wrap: Element, job: Job) {
    if (job.image_url) {
      const img = document.createElement('img');
      img.src = job.image_url;
      img.alt = job.title;
      img.loading = 'lazy';
      img.className = 'w-full h-full object-contain p-1';
      img.onerror = () => { img.remove(); showInitialAvatar(wrap, job.title); };
      wrap.appendChild(img);
    } else {
      showInitialAvatar(wrap, job.title);
    }
  }

  const IC_GLOBE = `<svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="5"/><path d="M1 6h10"/><path d="M6 1c-1.5 2-2 3.5-2 5s.5 3 2 5"/><path d="M6 1c1.5 2 2 3.5 2 5s-.5 3-2 5"/></svg>`;
  const IC_PIN   = `<svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 10.5S2.5 7 2.5 5a3.5 3.5 0 0 1 7 0C9.5 7 6 10.5 6 10.5z"/><circle cx="6" cy="5" r="1.2" fill="currentColor" stroke="none"/></svg>`;
  const IC_DOLLAR = `<svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 1.5v9M4.5 3.5h2a1.5 1.5 0 0 1 0 3H5a1.5 1.5 0 0 0 0 3h2.5"/></svg>`;
  const TAG_CLS  = 'inline-flex items-center gap-1 font-mono text-[0.55rem] tracking-[0.08em] uppercase border border-[#E8E8E8] text-[#666] px-2 py-[2px] rounded-full whitespace-nowrap leading-none';

  function buildTags(el: Element, job: Job) {
    const parts: string[] = [];

    if (job.is_remote === true)  parts.push(`<span class="${TAG_CLS}">${IC_GLOBE}Remote</span>`);
    if (job.is_remote === false) parts.push(`<span class="${TAG_CLS}">${IC_PIN}On-site</span>`);

    const locs = (job.locations ?? []).filter(l => job.is_remote !== true || l !== 'Worldwide');
    if (locs.length > 0) {
      const label = locs.length > 2 ? `${locs[0]}, ${locs[1]} +${locs.length - 2}` : locs.join(', ');
      parts.push(`<span class="${TAG_CLS}">${IC_PIN}${label}</span>`);
    }

    if (job.salary_min != null || job.salary_max != null)
      parts.push(`<span class="${TAG_CLS}">${IC_DOLLAR}Salary listed</span>`);

    el.innerHTML = parts.join('');
  }

  function buildRow(job: Job): DocumentFragment {
    const frag = (document.getElementById('tpl-row') as HTMLTemplateElement).content.cloneNode(true) as DocumentFragment;
    const article = frag.querySelector('article')!;
    (article.querySelector('.job-title') as HTMLElement).textContent = job.title;
    (article.querySelector('.job-description') as HTMLElement).textContent = job.description;
    (article.querySelector('.job-date') as HTMLElement).textContent = formatDate(job.created_at);
    (article.querySelector('.job-link') as HTMLAnchorElement).href = job.link;
    (article.querySelector('.job-card-link') as HTMLAnchorElement).href = `/job/${jobSlug(job.id, job.title)}/`;
    injectImage(article.querySelector('.job-image-wrap')!, job);
    buildTags(article.querySelector('.job-tags')!, job);
    return frag;
  }

  async function fetchPage(page: number): Promise<Job[]> {
    const from = page * PAGE_SIZE;
    const to   = from + PAGE_SIZE - 1;
    const res  = await fetch(
      `${SUPABASE_URL}/rest/v1/jobs?select=*&order=created_at.desc`,
      {
        headers: {
          apikey: SUPABASE_ANON_KEY,
          Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
          Range: `${from}-${to}`,
          Prefer: 'count=exact',
        },
      }
    );
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const range = res.headers.get('Content-Range'); // e.g. "0-9/42"
    if (range) {
      const match = range.match(/\/(\d+)$/);
      if (match) totalCount = parseInt(match[1], 10);
    }
    return res.json();
  }

  function renderPagination() {
    const totalPages = Math.ceil(totalCount / PAGE_SIZE);
    if (totalPages <= 1) { paginationEl.classList.add('hidden'); return; }

    paginationEl.classList.remove('hidden');
    indicatorEl.textContent = `Page ${currentPage + 1} of ${totalPages}`;
    (prevBtn as HTMLButtonElement).disabled = currentPage === 0;
    (nextBtn as HTMLButtonElement).disabled = currentPage >= totalPages - 1;
  }

  async function loadPage(page: number) {
    listEl.classList.add('hidden');
    paginationEl.classList.add('hidden');
    loadingEl.classList.remove('hidden');

    try {
      const jobs = await fetchPage(page);

      loadingEl.classList.add('hidden');

      if (page === 0 && jobs.length === 0) {
        emptyEl.classList.remove('hidden');
        countEl.textContent = '0 positions';
        return;
      }

      countEl.textContent = `${totalCount} position${totalCount !== 1 ? 's' : ''}`;
      listEl.innerHTML = '';
      jobs.forEach(job => listEl.appendChild(buildRow(job)));
      listEl.classList.remove('hidden');
      renderPagination();

      if (page === 0) injectJobPostingSchema(jobs);

    } catch {
      loadingEl.classList.add('hidden');
      errorEl.classList.remove('hidden');
      countEl.textContent = 'Error';
    }
  }

  prevBtn.addEventListener('click', () => {
    if (currentPage > 0) {
      currentPage--;
      window.scrollTo({ top: 0, behavior: 'smooth' });
      loadPage(currentPage);
    }
  });

  nextBtn.addEventListener('click', () => {
    const totalPages = Math.ceil(totalCount / PAGE_SIZE);
    if (currentPage < totalPages - 1) {
      currentPage++;
      window.scrollTo({ top: 0, behavior: 'smooth' });
      loadPage(currentPage);
    }
  });

  function injectJobPostingSchema(jobs: Job[]) {
    document.getElementById('ld-jobs')?.remove();
    const itemList = {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: 'Open AI Developer Positions — vibecoding.work',
      description: 'Jobs for vibecoders and AI-native software engineers.',
      url: 'https://vibecoding.work/',
      numberOfItems: totalCount,
      itemListElement: jobs.map((job, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'JobPosting',
          '@id': job.link,
          title: job.title,
          description: job.description,
          datePosted: job.created_at.split('T')[0],
          url: job.link,
          directApply: true,
          jobLocationType: 'TELECOMMUTE',
          applicantLocationRequirements: { '@type': 'Country', name: 'Worldwide' },
          employmentType: ['FULL_TIME', 'CONTRACTOR'],
          occupationalCategory: '15-1252',
          hiringOrganization: {
            '@type': 'Organization',
            name: 'vibecoding.work',
            sameAs: 'https://vibecoding.work',
            logo: 'https://vibecoding.work/images/logo.png',
          },
          ...(job.image_url ? { image: job.image_url } : {}),
        },
      })),
    };
    const script = document.createElement('script');
    script.id = 'ld-jobs';
    script.type = 'application/ld+json';
    script.textContent = JSON.stringify(itemList);
    document.head.appendChild(script);
  }

  loadPage(0);
</script>
