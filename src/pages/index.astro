---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="vibecoding.work — AI Developer Jobs & Remote Opportunities"
  description="Browse open positions for vibecoders and AI-native developers. Find jobs that embrace AI-assisted development and ship at the speed of thought."
>
  <Header />

  <main class="w-full">

    <!-- ─── Section header ─────────────────────────────────── -->
    <div class="px-6 md:px-12 py-3 border-b-2 border-[#1A1A1A] flex items-baseline justify-between">
      <div class="flex items-baseline gap-3">
        <h2 class="font-serif text-[1.5rem] md:text-[1.9rem] font-black uppercase tracking-tight leading-none text-[#1A1A1A]">
          Open Positions
        </h2>
        <div class="w-px h-4 bg-[#D0CEC8] hidden sm:block"></div>
        <span class="font-mono text-[11px] tracking-[0.25em] uppercase text-[#CC0000] hidden sm:block">
          AI-Native
        </span>
      </div>
      <span id="job-count" class="font-mono text-[11px] tracking-[0.2em] uppercase text-[#777]">
        Loading…
      </span>
    </div>

    <!-- ─── Loading skeleton ─────────────────────────────────── -->
    <div id="loading-state" class="divide-y divide-[#D0CEC8]">
      {[...Array(6)].map(() => (
        <div class="flex items-center gap-4 md:gap-6 px-6 md:px-12 h-[88px] animate-pulse">
<div class="flex-1 min-w-0 space-y-2">
            <div class="h-4 bg-[#EFEFEC] rounded w-2/5"></div>
            <div class="h-3 bg-[#EFEFEC] rounded w-3/4"></div>
          </div>
          <div class="h-2.5 w-20 bg-[#EFEFEC] rounded hidden md:block shrink-0"></div>
          <div class="h-2.5 w-14 bg-[#EFEFEC] rounded hidden sm:block shrink-0"></div>
          <div class="w-[64px] h-[64px] bg-[#EFEFEC] rounded-full shrink-0"></div>
        </div>
      ))}
    </div>

    <!-- ─── Empty state ─────────────────────────────────────── -->
    <div id="empty-state" class="hidden px-6 md:px-12 py-24 text-center border-b border-[#D0CEC8]">
      <p class="font-serif text-[2rem] font-black text-[#888] mb-3 leading-none">No positions yet.</p>
      <a href="/submit"
        class="font-mono text-[11px] tracking-[0.25em] uppercase text-[#666] hover:text-[#CC0000] transition-colors underline-offset-4 underline">
        Be the first to submit one ↗
      </a>
    </div>

    <!-- ─── Error state ──────────────────────────────────────── -->
    <div id="error-state" class="hidden px-6 md:px-12 py-12 text-center">
      <p class="font-mono text-[11px] tracking-[0.2em] uppercase text-[#CC0000]">
        Failed to load positions — check your Supabase configuration.
      </p>
    </div>

    <!-- ─── Job list ─────────────────────────────────────────── -->
    <div id="job-list" class="hidden divide-y divide-[#D0CEC8]"></div>

    <!-- ─── Pagination ───────────────────────────────────────── -->
    <div id="pagination" class="hidden px-6 md:px-12 py-5 border-t border-[#D0CEC8] flex items-center justify-between gap-4">
      <button id="page-prev"
        class="font-mono text-[11px] tracking-[0.25em] uppercase text-[#777]
               hover:text-[#1A1A1A] transition-colors duration-150 disabled:opacity-30 disabled:cursor-not-allowed">
        ← Prev
      </button>
      <span id="page-indicator" class="font-mono text-[10px] tracking-[0.2em] uppercase text-[#999]"></span>
      <button id="page-next"
        class="font-mono text-[11px] tracking-[0.25em] uppercase text-[#777]
               hover:text-[#1A1A1A] transition-colors duration-150 disabled:opacity-30 disabled:cursor-not-allowed">
        Next →
      </button>
    </div>

  </main>

  <Footer />
</Layout>

<!-- ═══════ ROW TEMPLATE ══════════════════════════════════════ -->
<template id="tpl-row">
  <article class="group relative flex items-center gap-4 md:gap-6 px-6 md:px-12 h-[88px] cursor-pointer
                  hover:bg-[#F2F0EC] transition-colors duration-150">

    <!-- Thumbnail — fixed 96 × 64 -->
    <div class="job-image-wrap w-[64px] h-[64px] shrink-0 overflow-hidden bg-white rounded-full border border-[#E8E6E2] flex items-center justify-center"></div>

<!-- Title + description -->
    <div class="flex-1 min-w-0">
      <h2 class="job-title font-serif font-black text-[1.05rem] leading-tight truncate
                 group-hover:text-[#CC0000] transition-colors duration-150"></h2>
      <p class="job-description font-sans text-[0.8rem] text-[#666] truncate mt-0.5 leading-snug"></p>
    </div>

    <!-- Date -->
    <span class="job-date font-mono text-[10px] tracking-[0.15em] text-[#777] uppercase
                 shrink-0 hidden md:block whitespace-nowrap"></span>

    <!-- Apply link -->
    <a class="job-link relative z-10 font-mono text-[11px] tracking-[0.25em] uppercase
              border-b border-[#1A1A1A] pb-px shrink-0 whitespace-nowrap
              hover:border-[#CC0000] hover:text-[#CC0000] transition-colors duration-150
              hidden sm:block"
       target="_blank" rel="noopener noreferrer">Apply ↗</a>

    <!-- Full-row tap target -->
    <a class="job-card-link absolute inset-0 z-0"
       aria-hidden="true" tabindex="-1"></a>
  </article>
</template>

<script>
  import { jobSlug } from '../lib/slug';

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const PAGE_SIZE = 10;

  type Job = { id: string; title: string; description: string; image_url: string | null; link: string; created_at: string; };

  let currentPage = 0;
  let totalCount   = 0;

  const loadingEl   = document.getElementById('loading-state')!;
  const emptyEl     = document.getElementById('empty-state')!;
  const errorEl     = document.getElementById('error-state')!;
  const countEl     = document.getElementById('job-count')!;
  const listEl      = document.getElementById('job-list')!;
  const paginationEl = document.getElementById('pagination')!;
  const prevBtn     = document.getElementById('page-prev') as HTMLButtonElement;
  const nextBtn     = document.getElementById('page-next') as HTMLButtonElement;
  const indicatorEl = document.getElementById('page-indicator')!;

  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase();
  }

  function showInitialAvatar(wrap: Element, title: string) {
    const letter = title.trim()[0]?.toUpperCase() ?? '?';
    wrap.innerHTML = `<span style="font-family:'IBM Plex Mono',monospace;font-size:1.3rem;font-weight:600;color:#1A1A1A;line-height:1;">${letter}</span>`;
  }

  function injectImage(wrap: Element, job: Job) {
    if (job.image_url) {
      const img = document.createElement('img');
      img.src = job.image_url;
      img.alt = job.title;
      img.loading = 'lazy';
      img.className = 'w-full h-full object-contain p-1';
      img.onerror = () => { img.remove(); showInitialAvatar(wrap, job.title); };
      wrap.appendChild(img);
    } else {
      showInitialAvatar(wrap, job.title);
    }
  }

  function buildRow(job: Job): DocumentFragment {
    const frag = (document.getElementById('tpl-row') as HTMLTemplateElement).content.cloneNode(true) as DocumentFragment;
    const article = frag.querySelector('article')!;
    (article.querySelector('.job-title') as HTMLElement).textContent = job.title;
    (article.querySelector('.job-description') as HTMLElement).textContent = job.description;
    (article.querySelector('.job-date') as HTMLElement).textContent = formatDate(job.created_at);
    (article.querySelector('.job-link') as HTMLAnchorElement).href = job.link;
    (article.querySelector('.job-card-link') as HTMLAnchorElement).href = `/job/${jobSlug(job.id, job.title)}/`;
    injectImage(article.querySelector('.job-image-wrap')!, job);
    return frag;
  }

  async function fetchPage(page: number): Promise<Job[]> {
    const from = page * PAGE_SIZE;
    const to   = from + PAGE_SIZE - 1;
    const res  = await fetch(
      `${SUPABASE_URL}/rest/v1/jobs?select=*&order=created_at.desc`,
      {
        headers: {
          apikey: SUPABASE_ANON_KEY,
          Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
          Range: `${from}-${to}`,
          Prefer: 'count=exact',
        },
      }
    );
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const range = res.headers.get('Content-Range'); // e.g. "0-9/42"
    if (range) {
      const match = range.match(/\/(\d+)$/);
      if (match) totalCount = parseInt(match[1], 10);
    }
    return res.json();
  }

  function renderPagination() {
    const totalPages = Math.ceil(totalCount / PAGE_SIZE);
    if (totalPages <= 1) { paginationEl.classList.add('hidden'); return; }

    paginationEl.classList.remove('hidden');
    indicatorEl.textContent = `Page ${currentPage + 1} of ${totalPages}`;
    (prevBtn as HTMLButtonElement).disabled = currentPage === 0;
    (nextBtn as HTMLButtonElement).disabled = currentPage >= totalPages - 1;
  }

  async function loadPage(page: number) {
    listEl.classList.add('hidden');
    paginationEl.classList.add('hidden');
    loadingEl.classList.remove('hidden');

    try {
      const jobs = await fetchPage(page);

      loadingEl.classList.add('hidden');

      if (page === 0 && jobs.length === 0) {
        emptyEl.classList.remove('hidden');
        countEl.textContent = '0 positions';
        return;
      }

      countEl.textContent = `${totalCount} position${totalCount !== 1 ? 's' : ''}`;
      listEl.innerHTML = '';
      jobs.forEach(job => listEl.appendChild(buildRow(job)));
      listEl.classList.remove('hidden');
      renderPagination();

      if (page === 0) injectJobPostingSchema(jobs);

    } catch {
      loadingEl.classList.add('hidden');
      errorEl.classList.remove('hidden');
      countEl.textContent = 'Error';
    }
  }

  prevBtn.addEventListener('click', () => {
    if (currentPage > 0) {
      currentPage--;
      window.scrollTo({ top: 0, behavior: 'smooth' });
      loadPage(currentPage);
    }
  });

  nextBtn.addEventListener('click', () => {
    const totalPages = Math.ceil(totalCount / PAGE_SIZE);
    if (currentPage < totalPages - 1) {
      currentPage++;
      window.scrollTo({ top: 0, behavior: 'smooth' });
      loadPage(currentPage);
    }
  });

  function injectJobPostingSchema(jobs: Job[]) {
    document.getElementById('ld-jobs')?.remove();
    const itemList = {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: 'Open AI Developer Positions — vibecoding.work',
      description: 'Jobs for vibecoders and AI-native software engineers.',
      url: 'https://vibecoding.work/',
      numberOfItems: totalCount,
      itemListElement: jobs.map((job, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'JobPosting',
          '@id': job.link,
          title: job.title,
          description: job.description,
          datePosted: job.created_at.split('T')[0],
          url: job.link,
          directApply: true,
          jobLocationType: 'TELECOMMUTE',
          applicantLocationRequirements: { '@type': 'Country', name: 'Worldwide' },
          employmentType: ['FULL_TIME', 'CONTRACTOR'],
          occupationalCategory: '15-1252',
          hiringOrganization: {
            '@type': 'Organization',
            name: 'vibecoding.work',
            sameAs: 'https://vibecoding.work',
            logo: 'https://vibecoding.work/images/logo.png',
          },
          ...(job.image_url ? { image: job.image_url } : {}),
        },
      })),
    };
    const script = document.createElement('script');
    script.id = 'ld-jobs';
    script.type = 'application/ld+json';
    script.textContent = JSON.stringify(itemList);
    document.head.appendChild(script);
  }

  loadPage(0);
</script>
