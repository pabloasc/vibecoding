---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { jobSlug } from '../../lib/slug';
import { createClient } from '@supabase/supabase-js';

type Job = {
  id: string;
  title: string;
  description: string;
  image_url: string | null;
  link: string;
  salary_min: number | null;
  salary_max: number | null;
  salary_currency: string | null;
  salary_period: string | null;
  valid_through: string | null;
  is_remote: boolean | null;
  locations: string[] | null;
  created_at: string;
};

// Extract the 8-char ID prefix appended to every slug
const { slug } = Astro.params;
const idMatch = slug?.match(/([0-9a-f]{8})$/i);
if (!idMatch) return Astro.redirect('/');
const idPrefix = idMatch[1].toLowerCase();

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

let job: Job | null = null;
try {
  const db = createClient(supabaseUrl, supabaseKey);
  const { data } = await db
    .from('jobs')
    .select('*')
    .gte('id', `${idPrefix}-0000-0000-0000-000000000000`)
    .lte('id', `${idPrefix}-ffff-ffff-ffff-ffffffffffff`)
    .limit(1)
    .maybeSingle();
  job = (data as Job) ?? null;
} catch { /* fall through */ }

if (!job) return Astro.redirect('/');

// 301-redirect non-canonical slugs (e.g. old builds with different title)
const canonicalSlug = jobSlug(job.id, job.title);
if (slug !== canonicalSlug) {
  return Astro.redirect(`/job/${canonicalSlug}/`, 301);
}

function formatDate(iso: string) {
  return new Date(iso)
    .toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' })
    .toUpperCase();
}

const canonicalUrl = `https://vibecoding.work/job/${canonicalSlug}/`;

const hasSalary = job.salary_min != null || job.salary_max != null;
const schemaJobPosting = {
  '@context': 'https://schema.org',
  '@type': 'JobPosting',
  title: job.title,
  description: job.description,
  datePosted: job.created_at.split('T')[0],
  url: canonicalUrl,
  directApply: true,
  jobLocationType: 'TELECOMMUTE',
  applicantLocationRequirements: { '@type': 'Country', name: 'Worldwide' },
  employmentType: ['FULL_TIME', 'CONTRACTOR'],
  occupationalCategory: '15-1252',
  hiringOrganization: {
    '@type': 'Organization',
    name: 'vibecoding.work',
    sameAs: 'https://vibecoding.work',
    logo: 'https://vibecoding.work/images/logo.png',
  },
  ...(job.valid_through ? { validThrough: job.valid_through } : {}),
  ...(hasSalary ? {
    baseSalary: {
      '@type': 'MonetaryAmount',
      currency: job.salary_currency ?? 'USD',
      value: {
        '@type': 'QuantitativeValue',
        ...(job.salary_min != null ? { minValue: job.salary_min } : {}),
        ...(job.salary_max != null ? { maxValue: job.salary_max } : {}),
        unitText: job.salary_period ?? 'YEAR',
      },
    },
  } : {}),
  ...(job.image_url ? { image: job.image_url } : {}),
};
---

<Layout
  title={`${job.title} — vibecoding.work`}
  description={job.description.substring(0, 160)}
  ogImage={job.image_url ?? '/og.svg'}
  type="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaJobPosting)} />
  </Fragment>

  <Header />

  <main class="w-full">

    <!-- Back bar -->
    <div class="px-6 md:px-12 py-3 border-b border-[#EBEBEB] flex items-center justify-between">
      <a href="/"
         class="font-mono text-[0.65rem] tracking-[0.18em] uppercase text-[#666]
                hover:text-[#0A0A0A] transition-colors duration-150">
        ← All Positions
      </a>
      <span class="font-mono text-[0.6rem] tracking-[0.12em] uppercase text-[#888]">
        {formatDate(job.created_at)}
      </span>
    </div>

    <!-- Admin bar -->
    <div id="admin-bar" class="hidden px-6 md:px-12 py-2.5 bg-[#0A0A0A] flex items-center gap-4">
      <span class="font-mono text-[0.6rem] tracking-[0.2em] uppercase text-[#444]">Admin</span>
      <span class="w-px h-3 bg-[#222]"></span>
      <a href={`/edit?id=${job.id}`}
         class="font-mono text-[0.65rem] tracking-[0.18em] uppercase text-white
                hover:text-[#CC0000] transition-colors duration-150">
        Edit →
      </a>
      <span class="w-px h-3 bg-[#222]"></span>
      <button id="delete-btn"
              data-job-id={job.id}
              class="font-mono text-[0.65rem] tracking-[0.18em] uppercase text-[#555]
                     hover:text-[#CC0000] transition-colors duration-150">
        Delete ×
      </button>
    </div>

    <!-- Content -->
    <div class="px-6 md:px-12 py-12 max-w-2xl">

      <!-- Company logo -->
      <div
        id="company-logo-wrap"
        class="mb-8"
        data-job-id={job.id}
        data-image={job.image_url ?? ''}
        data-title={job.title}
      ></div>

      <p class="font-mono text-[0.6rem] tracking-[0.3em] uppercase text-[#CC0000] mb-3">Open Position</p>

      <h1 class="font-sans font-bold text-[1.8rem] md:text-[2.4rem]
                 leading-tight tracking-tight text-[#0A0A0A] mb-4">{job.title}</h1>

      <!-- Meta tags: remote, location, salary -->
      {(job.is_remote !== null || (job.locations && job.locations.length > 0) || hasSalary) && (
        <div class="flex items-center gap-2 flex-wrap mb-8">

          {job.is_remote === true && (
            <span class="inline-flex items-center gap-1.5 font-mono text-[0.6rem] tracking-[0.1em] uppercase border border-[#E0E0E0] text-[#666] px-2.5 py-[3px] rounded-full">
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="5"/><path d="M1 6h10"/><path d="M6 1c-1.5 2-2 3.5-2 5s.5 3 2 5"/><path d="M6 1c1.5 2 2 3.5 2 5s-.5 3-2 5"/></svg>
              Remote
            </span>
          )}

          {job.is_remote === false && (
            <span class="inline-flex items-center gap-1.5 font-mono text-[0.6rem] tracking-[0.1em] uppercase border border-[#E0E0E0] text-[#666] px-2.5 py-[3px] rounded-full">
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1.5" y="2" width="9" height="9" rx="0.5"/><path d="M4.5 11V7.5h3V11"/><path d="M4 4.5h.5M7.5 4.5h.5"/></svg>
              On-site
            </span>
          )}

          {job.locations && job.locations.map(loc => (
            <span class="inline-flex items-center gap-1.5 font-mono text-[0.6rem] tracking-[0.1em] uppercase border border-[#E0E0E0] text-[#666] px-2.5 py-[3px] rounded-full">
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 10.5S2.5 7 2.5 5a3.5 3.5 0 0 1 7 0C9.5 7 6 10.5 6 10.5z"/><circle cx="6" cy="5" r="1.2" fill="currentColor" stroke="none"/></svg>
              {loc}
            </span>
          ))}

          {hasSalary && (
            <span class="inline-flex items-center gap-1.5 font-mono text-[0.6rem] tracking-[0.1em] uppercase border border-[#E0E0E0] text-[#666] px-2.5 py-[3px] rounded-full">
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 1.5v9M4.5 3.5h2a1.5 1.5 0 0 1 0 3H5a1.5 1.5 0 0 0 0 3h2.5"/></svg>
              Salary listed
            </span>
          )}

        </div>
      )}

      <div class="border-t border-[#EBEBEB] pt-8 mb-10">
        <p class="font-mono text-[0.6rem] tracking-[0.25em] uppercase text-[#888] mb-5">About this role</p>
        <p class="font-sans text-[0.95rem] leading-[1.75] text-[#444] whitespace-pre-wrap">{job.description}</p>
      </div>

      <div class="pt-2 flex items-center gap-5">
        <a href={job.link}
           target="_blank"
           rel="noopener noreferrer"
           class="font-mono text-[0.65rem] tracking-[0.25em] uppercase
                  bg-[#0A0A0A] text-white px-7 py-3.5
                  hover:bg-[#CC0000] transition-colors duration-200">
          Apply for this position ↗
        </a>
        <a href="/"
           class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-[#666]
                  hover:text-[#0A0A0A] transition-colors duration-200">
          ← Back
        </a>
      </div>

    </div>

  </main>

  <Footer />
</Layout>

<script>
  import { supabase } from '../../lib/supabase';
  const ADMIN_EMAIL = 'hi@vibecoders.co';

  // ── Company logo ─────────────────────────────────────────────
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  function showInitialAvatar(el: Element, title: string) {
    const letter = title.trim()[0]?.toUpperCase() ?? '?';
    el.innerHTML = `<span style="font-family:'IBM Plex Mono',monospace;font-size:2rem;font-weight:700;color:#1A1A1A;line-height:1;">${letter}</span>`;
  }

  function applyImage(el: Element, url: string, title: string) {
    el.innerHTML = '';
    if (!url) { showInitialAvatar(el, title); return; }
    const img = document.createElement('img');
    img.src = url;
    img.alt = title;
    img.style.cssText = 'max-height:56px;max-width:180px;width:auto;height:auto;object-fit:contain;display:block;';
    img.onerror = () => { img.remove(); showInitialAvatar(el, title); };
    el.appendChild(img);
  }

  const logoWrap    = document.getElementById('company-logo-wrap')!;
  const jobId       = logoWrap.dataset.jobId ?? '';
  const jobTitle    = logoWrap.dataset.title ?? '';
  const buildImage  = logoWrap.dataset.image ?? '';

  // Show build-time image immediately, then refresh from Supabase
  applyImage(logoWrap, buildImage, jobTitle);

  if (jobId) {
    fetch(
      `${SUPABASE_URL}/rest/v1/jobs?id=eq.${encodeURIComponent(jobId)}&select=image_url`,
      { headers: { apikey: SUPABASE_KEY, Authorization: `Bearer ${SUPABASE_KEY}` } }
    )
      .then(r => r.ok ? r.json() : null)
      .then((rows: { image_url: string | null }[] | null) => {
        const freshUrl = rows?.[0]?.image_url ?? '';
        if (freshUrl !== buildImage) applyImage(logoWrap, freshUrl, jobTitle);
      })
      .catch(() => {/* keep build-time image */});
  }

  // ── Admin check ───────────────────────────────────────────────
  async function checkAdmin() {
    const { data: { session } } = await supabase.auth.getSession();
    if (session?.user?.email === ADMIN_EMAIL) {
      document.getElementById('admin-bar')!.classList.remove('hidden');
    }
  }

  checkAdmin();

  // ── Delete position ───────────────────────────────────────────
  document.getElementById('delete-btn')?.addEventListener('click', async () => {
    if (!confirm('Permanently delete this position? This cannot be undone.')) return;

    const btn = document.getElementById('delete-btn') as HTMLButtonElement;
    btn.textContent = 'Deleting…';
    btn.disabled = true;

    const jobId = btn.dataset.jobId!;
    const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
    const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    const { data: { session } } = await supabase.auth.getSession();
    const token = session?.access_token;
    if (!token) { alert('Not authenticated.'); btn.textContent = 'Delete position ×'; btn.disabled = false; return; }

    const res = await fetch(
      `${SUPABASE_URL}/rest/v1/jobs?id=eq.${encodeURIComponent(jobId)}`,
      {
        method: 'DELETE',
        headers: {
          apikey: SUPABASE_KEY,
          Authorization: `Bearer ${token}`,
          Prefer: 'return=minimal',
        },
      }
    );

    if (res.ok) {
      window.location.href = '/';
    } else {
      alert('Failed to delete position.');
      btn.textContent = 'Delete position ×';
      btn.disabled = false;
    }
  });
</script>
